# ---------------------------------------------------------------------------
# Variáveis de ambiente do agentic-tabular-pipeline
# Copie este arquivo para `.env` e ajuste os valores conforme necessário.
# ---------------------------------------------------------------------------

# Conexão com o PostgreSQL (usada pela aplicação e pelas migrations)
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentic

# Credenciais usadas pelo serviço de banco no docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentic

# Diretório onde artefatos (modelos .pkl/.pt, relatórios) são gravados
ARTIFACT_DIR=artifacts/

# Seed global para reprodutibilidade
RANDOM_SEED=42

# Endpoints internos (usados pela UI para falar com a API)
API_URL=http://api:8000
# URL pública da API, usada em links que abrem no navegador do usuário (ex.: o
# painel /admin). Diferente de API_URL porque o navegador não resolve o hostname
# interno da rede Docker. Ajuste para o IP/domínio do host em produção.
API_PUBLIC_URL=http://localhost:8000

# Painel de administração (/admin) — credenciais de login e segredo do cookie
# de sessão. Troque os valores em produção; gere o segredo com:
#   python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_USER=admin
ADMIN_PASSWORD=admin
ADMIN_SECRET_KEY=1515552867f05d4b5c6f6a64ea38309ed61ce69fef55cd61c867ccad7d1b3c71
