# ---------------------------------------------------------------------------
# Variáveis de ambiente do agentic-tabular-pipeline
# Copie este arquivo para `.env` e ajuste os valores conforme necessário.
# ---------------------------------------------------------------------------

# Conexão com o PostgreSQL (usada pela aplicação e pelas migrations)
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentic

# Credenciais usadas pelo serviço de banco no docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentic

# Diretório onde artefatos (modelos .pkl/.pt, relatórios) são gravados
ARTIFACT_DIR=artifacts/

# Seed global para reprodutibilidade
RANDOM_SEED=42

# Endpoints internos (usados pela UI para falar com a API)
API_URL=http://api:8000
